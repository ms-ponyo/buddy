# Required: Slack Bot Token (xoxb-...)
SLACK_BOT_TOKEN=

# Required: Slack App-Level Token for Socket Mode (xapp-...)
SLACK_APP_TOKEN=

# Required: Absolute path to the project directory Claude will work in
PROJECT_DIR=

# Authentication: Either set ANTHROPIC_API_KEY or use `claude login` for OAuth
# ANTHROPIC_API_KEY=

# Optional: Claude model for main workers (default: claude-opus-4-6)
# CLAUDE_MODEL=claude-opus-4-6

# Optional: Claude model for lite workers / !commands (default: claude-haiku-4-5-20251001)
# DISPATCH_MODEL=claude-haiku-4-5-20251001

# Optional: Permission mode (default: default)
# Options: default, acceptEdits, bypassPermissions, dontAsk
# PERMISSION_MODE=default

# Optional: Log level (default: debug)
# LOG_LEVEL=debug

# Optional: Access control — comma-separated Slack user/channel IDs (empty = no restriction)
# ALLOWED_USER_IDS=U12345,U67890
# ALLOWED_CHANNEL_IDS=C12345,C67890
# ADMIN_USER_IDS=U12345

# Optional: Slack User Token for search API (xoxp-...)
# Required for search_messages tool. Get from OAuth & Permissions with search:read scope.
# SLACK_USER_TOKEN=

# Optional: Emoji reaction that triggers the bot (default: robot_face)
# TRIGGER_EMOJI=robot_face

# Optional: Preview mode for destructive tool operations (default: moderate)
# Options: off, moderate, destructive
# PREVIEW_MODE=moderate

# Optional: Path to project mappings file for multi-project support
# PROJECT_MAPPINGS_FILE=data/project-mappings.json

# Optional: Where to store smart permission patterns (default: projectSettings)
# Options: userSettings, projectSettings, localSettings, session, cliArg
# PERMISSION_DESTINATION=projectSettings
